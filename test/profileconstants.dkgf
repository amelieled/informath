ni : "#1 contains #2" | $#1 \ni #2$
disjoint : "#1 and #2 are disjoint" | "#1 is disjoint from #2" | $#1 \notmeets #2$
empty : "#1 is empty" | $#1 = \emptyset$
inhabited : "#1 is inhabited"
sameParity : "#1 and #2 have the same parity"


