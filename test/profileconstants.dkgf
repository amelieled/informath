Eq : "#1 is equal to #2" | "#1 and #2 are equal" | $#1 = #2$
Lt : Lt_Adj2 | $#1 < #2$
Gt : Gt_Adj2 | $#1 > #2$
Neq : "#1 is distinct from #2" | "#1 and #2 are distinct" | $#1 \neq #2$
